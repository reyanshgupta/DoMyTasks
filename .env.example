DOMYTASKS_TOKEN=change-me
DOMYTASKS_DB_PATH=/data/domytasks.db
DOMYTASKS_PORT=3603

# Skip the web login screen on trusted local setups (Docker on localhost, etc.).
# MCP and API bearer auth still require DOMYTASKS_TOKEN. Do not enable on public hosts.
DOMYTASKS_LOCAL_AUTO_LOGIN=true

# Web dashboard sessions. Set true when served only over HTTPS.
DOMYTASKS_WEB_SESSION_SECURE=false

# Optional Authelia trusted-header auth for the web/API behind a reverse proxy.
# Use the reverse proxy IP/CIDR. Use "*" only if DoMyTasks is unreachable except through that proxy.
DOMYTASKS_AUTHELIA_ENABLED=false
DOMYTASKS_AUTHELIA_TRUSTED_PROXIES=
# DOMYTASKS_AUTHELIA_ALLOWED_USERS=
# DOMYTASKS_AUTHELIA_ALLOWED_GROUPS=
